layout {
    pane split_direction="Vertical" {
        pane split_direction="Horizontal" size="60%" {
            pane size="70%" {
                command "hx"
                args "."
            }
            pane size="30%"
        }
        pane split_direction="Horizontal" size="40%" {
            pane size="50%" {
                command "claude"
            }
            pane size="50%" {
                command "lazygit"
            }
        }
    }
}
